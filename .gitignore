# Local data directories (runtime data lives in /home/pi/coaching-data/ outside the repo).
# Ignore the directory's contents but NOT the directory entry itself, so the negated paths below
# can re-include specific source-controlled assets (git won't descend into a fully-ignored dir).
/data/*
# ...the seeded base diagnostic framework artifact is a static, versioned source-controlled asset
# (the diagnostic spine) that ships with the app and is asserted by tests — keep it tracked.
!/data/frameworks/
/data/frameworks/*
!/data/frameworks/default.json
/review-queue/
/intake/
/CoachingPipeline/CoachingPipeline.Api/data/
/coaching-review-ui/playwright-report
/coaching-review-ui/test-results

# Ignore runtime temp run snapshots
.tmp/
/extraction-output
/docs/screens
