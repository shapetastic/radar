{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Radar": {
    "Collectors": [ "rss" ],
    "EvidenceSourceDirectory": "data/evidence",
    "EvidenceRawDirectory": "data/evidence/raw",
    "ReportDirectory": "data/reports",
    "CompanySeedFilePath": "data/companies.json",
    "ScoringWindowDays": 60,
    "ReportPeriodDays": 7,
    "ReportMaxItems": 25,
    "GenerateReport": true,
    "RunOnce": true,
    "IntervalMinutes": 60
  }
}
