{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Radar": {
    "Collectors": [ "rss" ],
    "Sec": {
      "UserAgent": "Radar Research example@example.com",
      "Forms": [ "8-K", "10-Q", "10-K" ],
      "MaxFilingsPerCompany": 25
    },
    "UsaSpending": {
      "AwardTypeCodes": [ "A", "B", "C", "D" ],
      "LookbackDays": 365,
      "MaxAwardsPerCompany": 25
    },
    "EvidenceSourceDirectory": "data/evidence",
    "EvidenceRawDirectory": "data/evidence/raw",
    "ReportDirectory": "data/reports",
    "CompanySeedFilePath": "data/companies.json",
    "ScoringWindowDays": 60,
    "ReportPeriodDays": 7,
    "ReportMaxItems": 25,
    "GenerateReport": true,
    "RunOnce": true,
    "IntervalMinutes": 60
  }
}
